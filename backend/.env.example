NODE_ENV=production
PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/freshroots?retryWrites=true&w=majority
MONGODB_DB_NAME=freshroots
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRE=30d

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

FRONTEND_URL=https://freshroots-web.onrender.com
CORS_ALLOWED_ORIGINS=https://freshroots-web.onrender.com
